# ── Server ─────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── OpenAI ─────────────────────────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

# ── Python Microservice (JobSpy) ───────────────────────────────────
PYTHON_SERVICE_URL=http://localhost:8000

# ── File Uploads ───────────────────────────────────────────────────
MAX_FILE_SIZE_MB=5
UPLOAD_DIR=./uploads

# ── CORS ───────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Feature Flags ──────────────────────────────────────────────────
# Set to "true" to use real OpenAI instead of dummy data
USE_AI=false
# Set to "true" to call Python JobSpy service instead of dummy jobs
USE_LIVE_JOBS=false
